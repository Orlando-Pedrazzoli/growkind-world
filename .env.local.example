# ============================================
# GROWKIND WORLD — Variáveis de Ambiente
# Copiar para .env.local e preencher
# ============================================

# ---- MongoDB ----
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/growkind?retryWrites=true&w=majority

# ---- Cloudinary ----
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- Brevo (Email Marketing) ----
BREVO_API_KEY=
NEXT_PUBLIC_BREVO_FORM_ID=

# ---- Stripe (Pagamentos) ----
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- Printful (POD) ----
PRINTFUL_API_KEY=

# ---- NextAuth.js ----
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# ---- Site ----
NEXT_PUBLIC_SITE_URL=https://growkindworld.com
NEXT_PUBLIC_SITE_NAME=GrowKind World
